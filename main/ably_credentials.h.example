/*
 * Ably API Credentials Template
 *
 * Copy this file to 'ably_credentials.h' and fill in your actual API keys.
 * The ably_credentials.h file is gitignored and will not be committed.
 */

#ifndef ABLY_CREDENTIALS_H
#define ABLY_CREDENTIALS_H

/*
 * Ably API Key for ESP32 RTK Base Station (Publisher)
 *
 * Create this key in Ably dashboard with capabilities:
 *   {"base.1.rtk":["publish","presence"]}
 *
 * Format: "key_name:key_secret"
 * Example: "abc123.xyz789:very_long_secret_string"
 */
#define ABLY_API_KEY_PUBLISHER "YOUR_PUBLISH_KEY_NAME:YOUR_PUBLISH_KEY_SECRET"

/*
 * Ably API Key for iOS App (Subscriber) - MVP ONLY
 *
 * Create this key in Ably dashboard with capabilities:
 *   {"base.1.rtk":["subscribe","presence"]}
 *
 * WARNING: For production, use token authentication instead!
 * This is only for MVP testing. DO NOT ship this in a production iOS app.
 *
 * Format: "key_name:key_secret"
 * Example: "def456.uvw012:another_long_secret_string"
 */
#define ABLY_API_KEY_SUBSCRIBER "YOUR_SUBSCRIBE_KEY_NAME:YOUR_SUBSCRIBE_KEY_SECRET"

/*
 * Ably Channel Name
 *
 * Channel where RTK corrections will be published/subscribed.
 * Must match the capability pattern in your API keys.
 */
#define ABLY_CHANNEL_NAME "base.1.rtk"

/*
 * MQTT Configuration
 */
#define ABLY_MQTT_BROKER "mqtt.ably.io"
#define ABLY_MQTT_PORT 8883
#define ABLY_MQTT_KEEPALIVE 30  // Seconds between keepalive pings

#endif // ABLY_CREDENTIALS_H
